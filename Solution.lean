    exact ⟨ Set.Nonempty.image _ ⟨ R, Set.left_mem_Ici ⟩, isPreconnected_Ici.image _ hu_cont ⟩;
  exact h_ivt.Icc_subset ( Set.mem_image_of_mem u h_no_zero.1.choose_spec.1 ) ( Set.mem_image_of_mem u h_no_zero.2.choose_spec.1 ) ⟨ h_no_zero.1.choose_spec.2, h_no_zero.2.choose_spec.2 ⟩

