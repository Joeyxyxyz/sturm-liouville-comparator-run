theorem wronskian_zero_of_l2 (V : ℝ → ℝ) (eigval : ℝ)
    (hV : IsConfiningPotential V)
    (u v : ℝ → ℝ)
    (hu : IsSturmLiouvilleEigenfunction V eigval u)
    (hv : IsSturmLiouvilleEigenfunction V eigval v) :
    ∀ x, wronskian u v x = 0 := by
      -- By definition of $wronskian$, we know that $wronskian u v x = u x * deriv v x - v x * deriv u x$ for all $x$.
      have h_wronskian_def : ∃ C : ℝ, ∀ x, wronskian u v x = C := by
        -- Apply the lemma that states the Wronskian of two eigenfunctions with the same eigenvalue is constant.
        apply wronskian_constant_same_eigenvalue V eigval u v hu hv;
      -- Since $u$ and $v$ are eigenfunctions, their limits at infinity are zero. Therefore, the Wronskian at infinity must also be zero.
      have h_wronskian_zero_at_infty : Filter.Tendsto (fun x => wronskian u v x) Filter.atTop (nhds 0) := by
        -- Apply the lemma that states the limits of $u$ and $v$ at infinity are zero.
        have h_u_v_zero : Filter.Tendsto u Filter.atTop (nhds 0) ∧ Filter.Tendsto v Filter.atTop (nhds 0) ∧ Filter.Tendsto (deriv u) Filter.atTop (nhds 0) ∧ Filter.Tendsto (deriv v) Filter.atTop (nhds 0) := by
          exact ⟨ tendsto_zero_and_deriv_zero_of_eigenfunction hV hu |>.1, tendsto_zero_and_deriv_zero_of_eigenfunction hV hv |>.1, tendsto_zero_and_deriv_zero_of_eigenfunction hV hu |>.2, tendsto_zero_and_deriv_zero_of_eigenfunction hV hv |>.2 ⟩;
        simpa [ wronskian ] using Filter.Tendsto.sub ( h_u_v_zero.1.mul h_u_v_zero.2.2.2 ) ( h_u_v_zero.2.1.mul h_u_v_zero.2.2.1 );
      aesop

theorem wronskian_zero_of_l2_final (V : ℝ → ℝ) (eigval : ℝ)
    (hV : IsConfiningPotential V)
    (u v : ℝ → ℝ)
    (hu : IsSturmLiouvilleEigenfunction V eigval u)
    (hv : IsSturmLiouvilleEigenfunction V eigval v) :
    ∀ x, wronskian u v x = 0 := by
      obtain ⟨C, hC⟩ : ∃ C : ℝ, ∀ x, wronskian u v x = C := by
        exact wronskian_constant_same_eigenvalue V eigval u v hu hv
      -- By the properties of the Wronskian, if $u$ and $v$ are solutions to the Sturm-Liouville equation with the same eigenvalue, then their Wronskian tends to zero as $x$ goes to infinity.
      have h_wronskian_zero : Filter.Tendsto (fun x => wronskian u v x) Filter.atTop (nhds 0) := by
        convert Filter.Tendsto.sub ( Filter.Tendsto.mul ( tendsto_zero_and_deriv_zero_of_eigenfunction_final hV hu |>.1 ) ( tendsto_zero_and_deriv_zero_of_eigenfunction_final hV hv |>.2 ) ) ( Filter.Tendsto.mul ( tendsto_zero_and_deriv_zero_of_eigenfunction_final hV hv |>.1 ) ( tendsto_zero_and_deriv_zero_of_eigenfunction_final hV hu |>.2 ) ) using 2 ; ring!;
      aesop

theorem linearly_dependent_of_wronskian_zero (V : ℝ → ℝ) (eigval : ℝ)
    (hV_cont : Continuous V)
    (u v : ℝ → ℝ)
    (hu : IsSturmLiouvilleEigenfunction V eigval u)
    (hv : IsSturmLiouvilleEigenfunction V eigval v)
    (hW : ∀ x, wronskian u v x = 0) :
    ∃ c : ℝ, ∀ x, v x = c * u x := by
      -- By definition of $IsSturmLiouvilleEigenfunction$, we know that $u$ and $v$ are solutions of the Sturm-Liouville equation.
      obtain ⟨hu_diff, hu_deriv_diff, hu_eq, hu_ne_zero, hu_memLp⟩ := hu
      obtain ⟨hv_diff, hv_deriv_diff, hv_eq, hv_ne_zero, hv_memLp⟩ := hv;
      -- Let $w(x) = v(x) - c u(x)$.
      obtain ⟨x₀, hx₀⟩ : ∃ x₀, u x₀ ≠ 0 := by
        exact Function.ne_iff.mp hu_ne_zero;
      -- Let $c = v(x₀) / u(x₀)$.
      set c : ℝ := v x₀ / u x₀;
      -- Let $w(x) = v(x) - c u(x)$. We need to show that $w(x) = 0$ for all $x$.
      set w : ℝ → ℝ := fun x => v x - c * u x;
      have hw_eq : ∀ x, deriv (deriv w) x = (V x - eigval) * w x := by
        intro x; rw [ show deriv w = fun x => deriv v x - deriv ( fun x => c * u x ) x from funext fun x => deriv_sub ( hv_diff.differentiableAt ) ( hu_diff.differentiableAt.const_mul _ ) ] ; norm_num [ hu_diff.differentiableAt, hu_deriv_diff.differentiableAt, hv_diff.differentiableAt, hv_deriv_diff.differentiableAt ] ; ring;
        linear_combination -hv_eq x + c * hu_eq x;
      have hw_zero : w x₀ = 0 ∧ deriv w x₀ = 0 := by
        simp +zetaDelta at *;
        norm_num [ hx₀, hu_diff.differentiableAt, hv_diff.differentiableAt ];
        simp_all +decide [ wronskian ];
        rw [ div_mul_eq_mul_div, sub_eq_zero, eq_div_iff hx₀ ] ; linarith [ hW x₀ ];
      have hw_zero_all : ∀ x, w x = 0 := by
        have hw_diff : Differentiable ℝ w := by
          exact Differentiable.sub hv_diff ( Differentiable.mul ( differentiable_const _ ) hu_diff )
        have hw_deriv_diff : Differentiable ℝ (deriv w) := by
          rw [ show deriv w = fun x => deriv v x - deriv ( fun x => c * u x ) x from funext fun x => deriv_sub ( hv_diff.differentiableAt ) ( hu_diff.differentiableAt.const_mul _ ) ] ; aesop
        apply zero_of_ode_zero_init hw_diff hw_deriv_diff ( show Continuous fun x => V x - eigval from hV_cont.sub continuous_const ) hw_eq hw_zero.1 hw_zero.2;
      exact ⟨ c, fun x => sub_eq_zero.mp ( hw_zero_all x ) ⟩

