          have h_eq : ∀ x ≥ x₀, deriv (deriv u) x = (V x - eigval) * u x := by
            exact fun x hx => by linarith [ hu.2.2.1 x ] ;
          cases hx₀.2 <;> simp_all +decide [ not_or, not_and ];
