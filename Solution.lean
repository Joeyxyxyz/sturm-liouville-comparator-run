      apply eventually_nonzero_of_confining_eigenfunction_aux_v8 hV hu

lemma tendsto_zero_and_deriv_zero_of_eigenfunction_fixed {V : ℝ → ℝ} {eigval : ℝ} {u : ℝ → ℝ}
