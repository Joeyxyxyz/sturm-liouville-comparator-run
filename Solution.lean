            · exact ⟨ fun h => by simpa using h.neg, fun h => by simpa using h.neg ⟩;
            · exact hu.1.differentiableOn.mono ( Set.Ici_subset_Ici.mpr le_rfl );
            · exact hu.2.1.differentiableOn.mono ( Set.Ici_subset_Ici.mpr le_rfl );
