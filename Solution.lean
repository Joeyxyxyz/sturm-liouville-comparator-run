def IsConfiningPotential (V : ℝ → ℝ) : Prop :=
  Continuous V ∧ Filter.Tendsto V (Filter.cocompact ℝ) Filter.atTop

def IsSturmLiouvilleEigenfunction (V : ℝ → ℝ) (eigval : ℝ) (u : ℝ → ℝ) : Prop :=
  Differentiable ℝ u ∧
  Differentiable ℝ (deriv u) ∧
  (∀ x, -(deriv (deriv u) x) + V x * u x = eigval * u x) ∧
  u ≠ 0 ∧
  MeasureTheory.MemLp u 2 MeasureTheory.volume

def wronskian (u v : ℝ → ℝ) (x : ℝ) : ℝ :=
  u x * deriv v x - v x * deriv u x

theorem wronskian_constant_same_eigenvalue (V : ℝ → ℝ) (eigval : ℝ)
    (u v : ℝ → ℝ)
    (hu : IsSturmLiouvilleEigenfunction V eigval u)
    (hv : IsSturmLiouvilleEigenfunction V eigval v) :
    ∃ C : ℝ, ∀ x, wronskian u v x = C := by
  -- By definition of $IsSturmLi ouvilleEigenfunction$, we know that $u$ and $ v$ satisfy the eigenvalue equation and are differentiable up to the second derivative.
  obtain ⟨hu_diff, hu_eigen, hu_mem⟩ := hu
  obtain ⟨hv_diff, hv_eigen, hv_mem⟩ := hv;
  -- The derivative of the Wronskian is zero, so the Wronskian is constant.
  have h_deriv_zero : ∀ x, deriv (fun x => wronskian u v x) x = 0 := by
    intro x; unfold wronskian; norm_num [ hu_diff.differentiableAt, hu_eigen.differentiableAt, hv_diff.differentiableAt, hv_eigen.differentiableAt ] ; ring;
    cases lt_or_ge ( u x ) 0 <;> cases lt_or_ge ( v x ) 0 <;> nlinarith [ hu_mem.1 x, hv_mem.1 x ];
  use wronskian u v 0;
  intro x; exact is_const_of_deriv_eq_zero ( fun x => DifferentiableAt.sub ( DifferentiableAt.mul ( hu_diff.differentiableAt ) ( hv_eigen.differentiableAt ) ) ( DifferentiableAt.mul ( hv_diff.differentiableAt ) ( hu_eigen.differentiableAt ) ) ) h_deriv_zero x 0;

