lemma tendsto_zero_and_deriv_zero_of_eigenfunction_final {V : ℝ → ℝ} {eigval : ℝ} {u : ℝ → ℝ}
    (hV : IsConfiningPotential V)
    (hu : IsSturmLiouvilleEigenfunction V eigval u) :
    Filter.Tendsto u Filter.atTop (nhds 0) ∧ Filter.Tendsto (deriv u) Filter.atTop (nhds 0) := by
      obtain ⟨R, hR⟩ : ∃ R : ℝ, ∀ x ≥ R, V x > eigval := by
        have := hV.2.eventually_gt_atTop eigval; aesop;
      
      have h_ode : ∀ x, deriv (deriv u) x = (V x - eigval) * u x := by
        intro x; have := hu.2.2.1 x; linarith
      
      have h_eventually_nonzero : ∃ R', ∀ x ≥ R', u x ≠ 0 := by
        apply eventually_nonzero_of_confining_eigenfunction_aux_v5 hV hu

      obtain ⟨R', hR'⟩ : ∃ R', ∀ x ≥ R', u x ≠ 0 := h_eventually_nonzero
      have h_constant_sign : (∀ x ≥ R', u x > 0) ∨ (∀ x ≥ R', u x < 0) := by
        apply constant_sign_of_no_zeros; exact hu.1.continuous.continuousOn; exact hR'
      cases' h_constant_sign with h_pos h_neg

      -- Case 1: $u(x) > 0$ for all $x \geq R'$.
      by_cases h_pos_case : ∀ x ≥ R', u x > 0
      
      -- Case 2: $u(x) < 0$ for all $x \geq R'$.
      by_cases h_neg_case : ∀ x ≥ R', u x < 0;
      · linarith [ h_pos_case R' le_rfl, h_neg_case R' le_rfl ];
      · apply tendsto_zero_of_convex_nonneg_l2_and_deriv u hu.1 hu.2.1 hu.2.2.2.2 (by
        filter_upwards [ Filter.eventually_ge_atTop R' ] with x hx using le_of_lt ( h_pos_case x hx )) (by
        have h_convex : ∀ᶠ x in Filter.atTop, deriv (deriv u) x = (V x - eigval) * u x := by
          exact Filter.Eventually.of_forall fun x => h_ode x
        filter_upwards [ h_convex, Filter.eventually_ge_atTop R, Filter.eventually_ge_atTop R' ] with x hx₁ hx₂ hx₃ using hx₁.symm ▸ mul_nonneg ( sub_nonneg.2 <| le_of_lt <| hR x hx₂ ) ( le_of_lt <| h_pos_case x hx₃ ));
      · contradiction;
      · -- Since $u(x) < 0$ for all $x \geq R'$, we can apply the same argument as in the case where $u(x) > 0$ for all $x \geq R'$.
        have h_neg_case : Filter.Tendsto (-u) Filter.atTop (nhds 0) ∧ Filter.Tendsto (deriv (-u)) Filter.atTop (nhds 0) := by
          apply_rules [ tendsto_zero_of_convex_nonneg_l2_and_deriv ];
          · exact hu.1.neg;
          · have := hu.2.1; aesop;
          · exact hu.2.2.2.2.neg;
          · filter_upwards [ Filter.eventually_ge_atTop R' ] with x hx using neg_nonneg_of_nonpos <| le_of_lt <| h_neg x hx;
          · have h_convex : ∀ᶠ x in Filter.atTop, deriv (deriv u) x ≤ 0 := by
              have h_convex : ∀ᶠ x in Filter.atTop, deriv (deriv u) x = (V x - eigval) * u x := by
                exact Filter.Eventually.of_forall fun x => h_ode x
              filter_upwards [ h_convex, Filter.eventually_ge_atTop R, Filter.eventually_ge_atTop R' ] with x hx₁ hx₂ hx₃ using by rw [ hx₁ ] ; nlinarith [ hR x hx₂, h_neg x hx₃ ] ;
            simp_all +decide [ show deriv ( -u ) = fun x => -deriv u x from funext fun x => deriv.neg ];
        exact ⟨ by simpa using h_neg_case.1.neg, by simpa using h_neg_case.2.neg ⟩

