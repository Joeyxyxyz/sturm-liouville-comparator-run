          exact h_contra R'' |> fun ⟨ x₀, hx₀₁, hx₀₂ ⟩ => ⟨ x₀, hx₀₁, hx₀₂ ⟩
        have h_deriv_nonzero : deriv u x₀ ≠ 0 := by
